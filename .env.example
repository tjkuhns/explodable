# Anthropic
ANTHROPIC_API_KEY=
# Model used for all LLM calls (planner, researcher, synthesizer, critic, content pipeline, BVCS)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Search APIs
TAVILY_API_KEY=
EXA_API_KEY=

# OpenAI (embeddings only)
OPENAI_API_KEY=

# Database
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=768

# Pipeline
OPERATOR_TIMEZONE=America/New_York
LOG_LEVEL=INFO

# Content selector — novelty decay factor for finding reuse across brands
# Higher = faster decay (findings become "stale" sooner). Default 0.3.
NOVELTY_DECAY_FACTOR=0.3
